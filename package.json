{
  "name": "soulclaw",
  "version": "0.2.0",
  "description": "Minimal AI assistant gateway for Feishu and Telegram",
  "type": "module",
  "engines": { "node": ">=22.0.0" },
  "scripts": {
    "start": "node --import tsx/esm src/main.ts",
    "dev": "node --watch --import tsx/esm src/main.ts",
    "build": "tsc --noEmit",
    "cli": "node --import tsx/esm src/cli.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "croner": "^10.0.1",
    "dotenv": "^17.3.1",
    "grammy": "^1.41.1",
    "openai": "^4.78.0",
    "ws": "^8.20.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@grammyjs/types": "^3.25.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
