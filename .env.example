# MinGate environment variables — copy to .env and fill in values
# Never commit .env to git

# Gateway access token for Web UI and CLI
# If unset, the UI is accessible without auth (only safe on localhost)
MINGATE_TOKEN=change-me-to-a-random-secret

# Telegram Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Public URL where Telegram will deliver webhook events (must be HTTPS)
# Example: https://myserver.example.com
TELEGRAM_PUBLIC_URL=

# Feishu / Lark app credentials (from Feishu Open Platform console)
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=

# AI model API key
# For Anthropic: sk-ant-...
# For OpenAI:    sk-...
MODEL_API_KEY=
